{
  "info": {
    "_postman_id": "fcf80c5e-307b-4f94-87af-bc1ee538a2fd",
    "name": "school-administration-system",
    "description": "This collection contains a focused set of API requests for the school-administration-system service running locally. It supports quick validation of the application’s availability and core school operations, including:\n\n- System checks: confirm the service is running via a healthcheck endpoint.\n    \n- Student data retrieval: fetch student lists both from an external student service and by internal class code (with pagination).\n    \n- Class management: update class details (e.g., class name) for a given class code.\n    \n- Reporting: generate a workload report for operational visibility.\n    \n- File handling: upload files to the system.\n    \n\nUse this collection to manually test and verify key endpoints during local development (e.g., localhost:3000 and localhost:5001) and to reproduce common API flows end-to-end.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "25447656"
  },
  "item": [
    {
      "name": "Healtcheck",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is < 2000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": []
        },
        "url": {
          "raw": "{{baseUrl}}/healthcheck",
          "host": ["{{baseUrl}}"],
          "path": ["healthcheck"]
        },
        "description": "Healthcheck for application"
      },
      "response": []
    },
    {
      "name": "Get Student List (External)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is JSON (when body is present)', function () {",
              "  pm.response.to.be.withBody;",
              "  pm.response.to.be.json;",
              "});",
              "",
              "pm.test('Response is non-empty when applicable', function () {",
              "  let json;",
              "  try {",
              "    json = pm.response.json();",
              "  } catch (e) {",
              "    return;",
              "  }",
              "",
              "  if (Array.isArray(json)) {",
              "    pm.expect(json.length).to.be.above(0);",
              "    return;",
              "  }",
              "",
              "  if (json && typeof json === 'object') {",
              "    const candidate = Array.isArray(json.data) ? json.data",
              "      : Array.isArray(json.items) ? json.items",
              "      : null;",
              "",
              "    if (candidate) {",
              "      pm.expect(candidate.length).to.be.above(0);",
              "    }",
              "  }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{externalBaseUrl}}/students?class=P1-1&offset=0&limit=500",
          "host": ["{{externalBaseUrl}}"],
          "path": ["students"],
          "query": [
            {
              "key": "class",
              "value": "P1-1"
            },
            {
              "key": "offset",
              "value": "0"
            },
            {
              "key": "limit",
              "value": "500"
            }
          ]
        },
        "description": "Retrieving student list from external"
      },
      "response": []
    },
